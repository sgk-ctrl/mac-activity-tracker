<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>MacBook Activity &middot; Biweekly Review</title>
<script src="__CHART_SRC__"></script>
<style>
  :root{
    --bg:#0d1117; --panel:#161b22; --panel2:#1c2330; --line:#293040;
    --txt:#e6edf3; --mut:#8b949e; --acc:#4c9aff; --good:#3fb950; --warn:#d29922; --bad:#f85149;
    --ai:#a371f7;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--txt);
       font-family:-apple-system,BlinkMacSystemFont,"SF Pro Text",Segoe UI,Roboto,sans-serif;}
  .wrap{max-width:1180px;margin:0 auto;padding:28px 20px 60px}
  header{display:flex;flex-wrap:wrap;align-items:baseline;gap:12px;justify-content:space-between;margin-bottom:6px}
  h1{font-size:22px;margin:0;font-weight:650}
  .sub{color:var(--mut);font-size:13px}
  .pill{display:inline-block;background:var(--panel2);border:1px solid var(--line);
        border-radius:999px;padding:3px 10px;font-size:12px;color:var(--mut)}
  h2{font-size:15px;margin:30px 0 12px;font-weight:600}
  .kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(165px,1fr));gap:12px;margin-top:16px}
  .kpi{background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:14px 16px}
  .kpi .n{font-size:26px;font-weight:680;letter-spacing:-.5px}
  .kpi .l{color:var(--mut);font-size:12px;margin-top:2px}
  .kpi .d{font-size:11px;margin-top:6px}
  .up{color:var(--good)} .down{color:var(--bad)} .neu{color:var(--mut)}
  .grid{display:grid;gap:14px}
  .g2{grid-template-columns:1fr 1fr}
  .g3{grid-template-columns:1.3fr 1fr 1fr}
  @media(max-width:820px){.g2,.g3{grid-template-columns:1fr}}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:16px}
  .card h3{margin:0 0 12px;font-size:13px;font-weight:600;color:var(--mut);text-transform:uppercase;letter-spacing:.4px}
  canvas{max-height:260px}
  .assess{background:linear-gradient(180deg,var(--panel2),var(--panel));border:1px solid var(--line);border-radius:14px;padding:20px}
  .ins{display:flex;gap:12px;padding:12px 0;border-top:1px solid var(--line)}
  .ins:first-of-type{border-top:none}
  .ins .ic{font-size:18px;flex:0 0 26px;text-align:center}
  .ins .body b{font-size:14px}
  .ins .body p{margin:3px 0 0;color:var(--mut);font-size:13px;line-height:1.5}
  .tag{font-size:10px;font-weight:700;padding:1px 7px;border-radius:5px;margin-left:6px;vertical-align:middle}
  .t-eff{background:#1f6feb33;color:#79c0ff;border:1px solid #1f6feb66}
  .t-tool{background:#a371f733;color:#d2a8ff;border:1px solid #a371f766}
  .t-watch{background:#d2992233;color:#e3b341;border:1px solid #d2992266}
  .rec{background:var(--panel);border:1px solid var(--line);border-left:3px solid var(--ai);
       border-radius:8px;padding:12px 14px;margin-top:10px}
  .rec b{font-size:13px}
  .rec p{margin:4px 0 0;color:var(--mut);font-size:12.5px;line-height:1.5}
  .rec code{background:#0d111788;border:1px solid var(--line);border-radius:4px;padding:1px 5px;font-size:11.5px}
  footer{color:var(--mut);font-size:12px;margin-top:34px;text-align:center;line-height:1.6}
  .legend{display:flex;flex-wrap:wrap;gap:12px;margin-top:10px;font-size:12px;color:var(--mut)}
  .legend span{display:inline-flex;align-items:center;gap:5px}
  .dot{width:9px;height:9px;border-radius:2px;display:inline-block}
  .empty{text-align:center;color:var(--mut);padding:60px 20px}
  .caveat{color:var(--mut);font-size:11px;margin-top:8px}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <div>
      <h1>MacBook Activity &mdash; Biweekly Review</h1>
      <div class="sub" id="window"></div>
    </div>
    <span class="pill" id="src"></span>
  </header>

  <div id="app"></div>
</div>

<!-- Data is embedded as INERT JSON (not executable JS). Parsed with JSON.parse. -->
<script id="activity-data" type="application/json">__DATA__</script>
<script>
"use strict";
const esc = s => String(s).replace(/[&<>"']/g, c =>
  ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));
const DATA = JSON.parse(document.getElementById("activity-data").textContent);
const S = Array.isArray(DATA.sessions) ? DATA.sessions : [];

document.getElementById("src").textContent =
  DATA.source === "sample" ? "SAMPLE DATA" : (DATA.redacted ? "LIVE · REDACTED" : "LIVE DATA");

if (!S.length) {
  document.getElementById("window").textContent = `${DATA.window_start} → ${DATA.window_end}`;
  document.getElementById("app").innerHTML =
    '<div class="empty"><h2>No activity yet</h2>' +
    '<p>Run <code>python3 tracker.py</code> to collect data, then rebuild this dashboard.</p></div>';
} else {
  render();
}

function render() {
  const FOCUS = new Set(["Coding","AI / Agentic"]);
  const DIST  = new Set(["Social","Media","Shopping"]);
  const COMM  = new Set(["Communication","Meetings"]);
  const CATCOLORS = {
    "Coding":"#4c9aff","AI / Agentic":"#a371f7","Communication":"#3fb950","Meetings":"#2da44e",
    "Browsing":"#58a6ff","Docs / Notes":"#e3b341","Design":"#db61a2","Media":"#f0883e",
    "Social":"#f85149","News / Reading":"#56d364","Shopping":"#ff7b72","Other":"#8b949e"};
  const catColor = c => CATCOLORS[c] || "#8b949e";
  const fmtH = m => (m/60).toFixed(1)+"h";
  const sum = a => a.reduce((x,y)=>x+y,0);
  const by = key => { const m={}; S.forEach(s=>{const k=typeof key==="function"?key(s):s[key];
    m[k]=(m[k]||0)+s.minutes;}); return m; };
  const topN = (o,n) => Object.entries(o).sort((a,b)=>b[1]-a[1]).slice(0,n);

  const catMin = by("category");
  const totalMin = sum(Object.values(catMin)) || 1;
  const appMin={}, siteMin={}, aiMin={};
  S.forEach(s=>{ const t = s.kind==="web"?siteMin:appMin; t[s.name]=(t[s.name]||0)+s.minutes; });
  S.filter(s=>s.is_agentic).forEach(s=>aiMin[s.name]=(aiMin[s.name]||0)+s.minutes);

  const days=[...new Set(S.map(s=>s.start.slice(0,10)))].sort();
  const nDays=days.length||1;
  const focusMin=sum(S.filter(s=>FOCUS.has(s.category)).map(s=>s.minutes));
  const distMin =sum(S.filter(s=>DIST.has(s.category)).map(s=>s.minutes));
  const commMin =sum(S.filter(s=>COMM.has(s.category)).map(s=>s.minutes));
  const agenticMin=sum(S.filter(s=>s.is_agentic).map(s=>s.minutes));

  const byDay={}; S.forEach(s=>{(byDay[s.start.slice(0,10)]=byDay[s.start.slice(0,10)]||[]).push(s);});
  // count only app-to-app changes: mixing web visits in would inflate the
  // number with every alternation between a browser tab and its host browser
  let switches=0;
  Object.values(byDay).forEach(a=>{const apps=a.filter(s=>s.kind==="app").sort((x,y)=>x.start<y.start?-1:1);
    for(let i=1;i<apps.length;i++) if(apps[i].name!==apps[i-1].name) switches++;});
  const switchesDay=Math.round(switches/nDays);

  const distEntries=Object.entries(by("name")).filter(([n])=>{
    const s=S.find(x=>x.name===n); return s&&DIST.has(s.category);}).sort((a,b)=>b[1]-a[1]);
  const topDist=distEntries[0]||["—",0];

  const hours=Array(24).fill(0); S.forEach(s=>{hours[+s.start.slice(11,13)]+=s.minutes;});
  const peakHour=()=>{let mi=9,mv=-1;hours.forEach((v,h)=>{if(h>=7&&h<=20&&v>mv){mv=v;mi=h;}});return mi;};

  // ---- build DOM skeleton ----
  document.getElementById("app").innerHTML = `
    <div class="kpis" id="kpis"></div>
    <h2>Where the time went <span class="sub">(durations are estimates)</span></h2>
    <div class="grid g3">
      <div class="card"><h3>Time by category</h3><canvas id="catChart"></canvas><div class="legend" id="catLegend"></div></div>
      <div class="card"><h3>Top applications</h3><canvas id="appChart"></canvas></div>
      <div class="card"><h3>Top websites</h3><canvas id="siteChart"></canvas></div>
    </div>
    <div class="grid g2" style="margin-top:14px">
      <div class="card"><h3>Daily focus vs. distraction</h3><canvas id="dayChart"></canvas></div>
      <div class="card"><h3>Agentic / AI tool usage</h3><canvas id="aiChart"></canvas><div class="legend" id="aiLegend"></div></div>
    </div>
    <div class="card" style="margin-top:14px"><h3>Active hours by hour of day</h3><canvas id="hourChart" style="max-height:180px"></canvas></div>
    <h2>Biweekly assessment</h2>
    <div class="assess"><div id="insights"></div>
      <h3 style="color:var(--mut);font-size:12px;text-transform:uppercase;letter-spacing:.4px;margin:20px 0 4px">
        Recommended next steps &mdash; tools &amp; workflows to amplify how you work</h3>
      <div id="recs"></div></div>
    <footer id="foot"></footer>`;

  document.getElementById("window").textContent =
    `${DATA.window_start} → ${DATA.window_end} · ${nDays} days · generated ${String(DATA.generated_at).replace("T"," ")}`;

  const pctFocus=Math.round(focusMin/totalMin*100);
  const pctDist=Math.round(distMin/totalMin*100);
  const pctAgentic=Math.round(agenticMin/totalMin*100);
  const commPct=Math.round(commMin/totalMin*100);

  const kpis=[
    {n:fmtH(totalMin), l:"Total active time (est.)", d:`${(totalMin/60/nDays).toFixed(1)}h / day avg`, c:"neu"},
    {n:pctFocus+"%", l:"Deep-focus (Coding + AI)", d:`${fmtH(focusMin)} over ${nDays} days`, c:pctFocus>45?"up":"neu"},
    {n:fmtH(agenticMin), l:"Agentic / AI tools", d:pctAgentic+"% of active time", c:"up"},
    {n:switchesDay, l:"App switches / day", d:switchesDay>60?"high fragmentation":"moderate", c:switchesDay>60?"down":"neu"},
    {n:fmtH(distMin), l:"Distraction time", d:`top: ${topDist[0]} (${fmtH(topDist[1])})`, c:pctDist>18?"down":"neu"},
  ];
  document.getElementById("kpis").innerHTML = kpis.map(k=>
    `<div class="kpi"><div class="n">${esc(k.n)}</div><div class="l">${esc(k.l)}</div>
     <div class="d ${k.c}">${esc(k.d)}</div></div>`).join("");

  Chart.defaults.color="#8b949e"; Chart.defaults.borderColor="#29304099"; Chart.defaults.font.size=11;

  const catTop=Object.entries(catMin).sort((a,b)=>b[1]-a[1]);
  new Chart(catChart,{type:"doughnut",data:{labels:catTop.map(x=>x[0]),
    datasets:[{data:catTop.map(x=>+(x[1]/60).toFixed(1)),backgroundColor:catTop.map(x=>catColor(x[0])),borderWidth:0}]},
    options:{plugins:{legend:{display:false}},cutout:"62%"}});
  document.getElementById("catLegend").innerHTML=catTop.map(x=>
    `<span><i class="dot" style="background:${catColor(x[0])}"></i>${esc(x[0])} ${(x[1]/60).toFixed(1)}h</span>`).join("");

  const appTop=topN(appMin,8);
  new Chart(appChart,{type:"bar",data:{labels:appTop.map(x=>x[0]),
    datasets:[{data:appTop.map(x=>+(x[1]/60).toFixed(1)),backgroundColor:"#4c9aff",borderRadius:4}]},
    options:{indexAxis:"y",plugins:{legend:{display:false}},scales:{x:{title:{display:true,text:"hours"}}}}});

  const siteTop=topN(siteMin,8);
  new Chart(siteChart,{type:"bar",data:{labels:siteTop.map(x=>x[0]),
    datasets:[{data:siteTop.map(x=>+(x[1]/60).toFixed(1)),backgroundColor:"#56d364",borderRadius:4}]},
    options:{indexAxis:"y",plugins:{legend:{display:false}},scales:{x:{title:{display:true,text:"visits × est. dwell (hrs)"}}}}});

  const dFocus=days.map(d=>sum((byDay[d]||[]).filter(s=>FOCUS.has(s.category)).map(s=>s.minutes))/60);
  const dComm =days.map(d=>sum((byDay[d]||[]).filter(s=>COMM.has(s.category)).map(s=>s.minutes))/60);
  const dDist =days.map(d=>sum((byDay[d]||[]).filter(s=>DIST.has(s.category)).map(s=>s.minutes))/60);
  const dOther=days.map((d,i)=>{const t=sum((byDay[d]||[]).map(s=>s.minutes))/60;return +(t-dFocus[i]-dComm[i]-dDist[i]).toFixed(2);});
  new Chart(dayChart,{type:"bar",data:{labels:days.map(d=>d.slice(5)),datasets:[
    {label:"Focus",data:dFocus,backgroundColor:"#a371f7"},
    {label:"Comms/Mtg",data:dComm,backgroundColor:"#3fb950"},
    {label:"Other",data:dOther,backgroundColor:"#8b949e"},
    {label:"Distraction",data:dDist,backgroundColor:"#f85149"}]},
    options:{plugins:{legend:{position:"bottom"}},scales:{x:{stacked:true},y:{stacked:true,title:{display:true,text:"hours"}}}}});

  const aiTop=Object.entries(aiMin).sort((a,b)=>b[1]-a[1]);
  const aiColors=["#a371f7","#d2a8ff","#4c9aff","#56d364","#e3b341","#f0883e"];
  new Chart(aiChart,{type:"doughnut",data:{labels:aiTop.map(x=>x[0]),
    datasets:[{data:aiTop.map(x=>+(x[1]/60).toFixed(1)),backgroundColor:aiColors,borderWidth:0}]},
    options:{plugins:{legend:{display:false}},cutout:"62%"}});
  document.getElementById("aiLegend").innerHTML=aiTop.length?aiTop.map((x,i)=>
    `<span><i class="dot" style="background:${aiColors[i%aiColors.length]}"></i>${esc(x[0])} ${(x[1]/60).toFixed(1)}h</span>`).join("")
    : '<span>No agentic-tool usage detected in this window.</span>';

  new Chart(hourChart,{type:"bar",data:{labels:[...Array(24).keys()].map(h=>h+":00"),
    datasets:[{data:hours.map(m=>+(m/60).toFixed(1)),backgroundColor:hours.map(m=>m>0?"#4c9aff":"#293040"),borderRadius:3}]},
    options:{plugins:{legend:{display:false}},scales:{y:{title:{display:true,text:"hours (window total)"}}}}});

  // ---- assessment ----
  const insights=[
    {ic:"🧠",t:["Focus","t-eff"],b:`Deep-focus work was ${pctFocus}% of your active time`,
     p:`~${fmtH(focusMin)} on Coding + AI across ${nDays} days. Your most active window is around ${peakHour()}:00 — protect it from meetings.`},
    {ic:"🤖",t:["Tools","t-tool"],b:`Agentic tools are ~${pctAgentic}% of your workflow`,
     p:`Agentic/AI tools ran ~${fmtH(agenticMin)}. Strong base — the leverage now is chaining them so context passes automatically instead of copy-paste.`},
    {ic:"🔀",t:["Efficiency","t-eff"],b:`~${switchesDay} app switches per day`,
     p:`Context-switching is the biggest hidden tax here. Batching comms (${commPct}% of time) into 2–3 fixed blocks would recover focus time.`},
    {ic:"⚠️",t:["Watch","t-watch"],b:`${pctDist}% of active time was distraction (${topDist[0]} led)`,
     p:`~${fmtH(distMin)} over ${nDays} days. Most clustered in the evening — a soft site limit after 20:00 would catch it.`},
  ];
  document.getElementById("insights").innerHTML=insights.map(i=>
    `<div class="ins"><div class="ic">${i.ic}</div><div class="body"><b>${esc(i.b)}</b>
     <span class="tag ${i.t[1]}">${esc(i.t[0])}</span><p>${i.p}</p></div></div>`).join("");

  const aiNames = aiTop.slice(0,3).map(x=>esc(x[0])).join(", ") || "your AI tools";
  const recs=[
    {b:"Chain your agentic tools instead of switching between them",
     p:`Give <code>${aiNames}</code> a single entry point that routes a task to the right one and passes context along — kills the copy-paste tax between them.`},
    {b:"Auto-batch communications",
     p:`Comms + meetings were ${commPct}% of active time and interleaved with focus work. Holding Slack/Mail outside 2–3 daily windows attacks your ${switchesDay}-switch/day number.`},
    {b:"Keep the tracker running and let it self-assess every 2 weeks",
     p:`Run <code>tracker.py</code> for real data and schedule <code>scripts/run_review.sh</code> biweekly. Each run refreshes this dashboard and re-computes the assessment.`},
    {b:"Add a soft evening guardrail for the top distraction",
     p:`${esc(topDist[0])} was #1 (${fmtH(topDist[1])}). A single Screen Time limit after 20:00 is low-effort, high-return — no full blocker needed.`},
  ];
  document.getElementById("recs").innerHTML=recs.map(r=>
    `<div class="rec"><b>${esc(r.b)}</b><p>${r.p}</p></div>`).join("");

  document.getElementById("foot").innerHTML =
    `100% local · no network calls · Chart.js is vendored, not fetched · source: <b>${esc(DATA.source||"?")}</b><br>` +
    `Durations are heuristic estimates. This file embeds your data — don't share it publicly.`;
}
</script>
</body>
</html>
